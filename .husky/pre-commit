#!/usr/bin/env bash

# Run Foundry formatting for staged Solidity changes under contracts/evm.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_sol=()
while IFS= read -r file; do
  staged_sol+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACM | grep '^contracts/evm/.*\.sol$' || true)

if [ ${#staged_sol[@]} -eq 0 ]; then
  exit 0
fi

if ! command -v forge >/dev/null 2>&1; then
  echo "forge is not installed or not on PATH. Install Foundry (see contracts/evm/README.md)." >&2
  exit 1
fi

cd "$repo_root/contracts/evm"

relative_paths=()
for path in "${staged_sol[@]}"; do
  relative_paths+=("${path#contracts/evm/}")
done

forge fmt --files "${relative_paths[@]}"

cd "$repo_root"
git add -- "${staged_sol[@]}"
