# =============================================================================
# Arbitrum Sepolia Testnet Commands
# =============================================================================

# Wrap ETH to WETH on Arbitrum Sepolia testnet
wrap-eth-sepolia:
    cast send {{ weth_sepolia }} "deposit()" \
        --value {{ weth_amount }} \
        --rpc-url $ARB_SEPOLIA_RPC_URL \
        --private-key $PRIVATE_KEY

# Create WETH/USDC market on Arbitrum Sepolia testnet
create-market-sepolia:
    NETWORK=sepolia \
    UNDERLYING_ASSET_0={{ weth_sepolia }} \
    UNDERLYING_ASSET_1={{ usdc_sepolia }} \
    CORE_POOL_FEE=0 \
    TICK_SPACING=60 \
    INITIAL_SQRT_PRICE_X96={{ sqrt_price_sepolia }} \
    forge script {{ script_dir }}/CreateMarket.s.sol:CreateMarketScript \
        --rpc-url $ARB_SEPOLIA_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

# Add liquidity to WETH/USDC market on Arbitrum Sepolia testnet
add-liquidity-sepolia:
    NETWORK=sepolia \
    UNDERLYING_ASSET_0={{ weth_sepolia }} \
    UNDERLYING_ASSET_1={{ usdc_sepolia }} \
    CORE_POOL_FEE=0 \
    TICK_SPACING=60 \
    UNDERLYING_ASSET_0_AMOUNT={{ weth_amount }} \
    forge script {{ script_dir }}/AddLiquidity.s.sol:AddLiquidityScript \
        --rpc-url $ARB_SEPOLIA_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

# Execute swap on Arbitrum Sepolia testnet
swap-sepolia core_pool_id="":
    #!/usr/bin/env bash
    set -euo pipefail
    NETWORK=sepolia \
    SWAP_TYPE=0 \
    CORE_POOL_ID="{{ core_pool_id }}" \
    AMOUNT={{ swap_amount }} \
    forge script {{ script_dir }}/SwapV4.s.sol:SwapV4 \
        --rpc-url $ARB_SEPOLIA_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

# =============================================================================
# Arbitrum Mainnet Commands
# =============================================================================

# Create ARB/USDT market on Arbitrum Mainnet
create-market-mainnet:
    NETWORK=arbitrum \
    UNDERLYING_ASSET_0={{ arb_mainnet }} \
    UNDERLYING_ASSET_1={{ usdt_mainnet }} \
    CORE_POOL_FEE=500 \
    TICK_SPACING=10 \
    REFERENCE_POOL_ID=0x90adeaeba1b0550987637183712c138484af473093e2006a0fecaad3241ddb1c \
    REFERENCE_POOL_CURRENCY0={{ arb_mainnet }} \
    REFERENCE_POOL_CURRENCY1={{ usdt_mainnet }} \
    forge script {{ script_dir }}/CreateMarket.s.sol:CreateMarketScript \
        --rpc-url $ARB_MAINNET_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

# Add liquidity to ARB/USDT market on Arbitrum Mainnet
add-liquidity-mainnet:
    NETWORK=arbitrum \
    UNDERLYING_ASSET_0={{ arb_mainnet }} \
    UNDERLYING_ASSET_1={{ usdt_mainnet }} \
    CORE_POOL_FEE=500 \
    TICK_SPACING=10 \
    RANGE_WIDTH=0 \
    UNDERLYING_ASSET_1_AMOUNT={{ usdt_amount }} \
    forge script {{ script_dir }}/AddLiquidity.s.sol:AddLiquidityScript \
        --rpc-url $ARB_MAINNET_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

# Remove liquidity from market on Arbitrum Mainnet
remove-liquidity-mainnet:
    NETWORK=arbitrum \
    forge script {{ script_dir }}/RemoveLiquidity.s.sol:RemoveLiquidityScript \
        --rpc-url $ARB_MAINNET_RPC_URL \
        -vvvv \
        --ffi \
        --sig "run()" \
        --with-gas-price {{ gas_price }} \
        {{ args }}

