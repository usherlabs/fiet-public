# Unwrap all WETH to ETH on Ethereum Sepolia testnet
unwrap-eth-ethsepolia:
    #!/usr/bin/env bash
    set -euo pipefail
    ADDRESS=$(cast wallet address --private-key $PRIVATE_KEY)
    BAL_HEX=$(cast call {{ weth_ethsepolia }} "balanceOf(address)(uint256)" $ADDRESS --rpc-url $ETH_SEPOLIA_RPC_URL)
    BALANCE=$(cast --to-decimal $BAL_HEX)
    if [ $BALANCE -eq 0 ]; then
        echo "No WETH to unwrap"
    else
        cast send {{ weth_ethsepolia }} "withdraw(uint256)" $BALANCE \
            --rpc-url $ETH_SEPOLIA_RPC_URL \
            --private-key $PRIVATE_KEY
    fi
