        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Persist UNDERLYING_ASSET_0/1 based on mock deployments
set-underlyings:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ mode }}" != "LOCAL" ]; then
        echo "set-underlyings is intended for MODE=LOCAL. Skipping."
        exit 0
    fi
    DEPLOYMENTS_FILE="deployments/local_{{ network }}_deployments.json"
    if [ ! -f "$DEPLOYMENTS_FILE" ]; then
        echo "Expected $DEPLOYMENTS_FILE not found. Run \`just deploy-tokenA\` and \`just deploy-tokenB\` first."
        exit 1
    fi
    UA0="$(jq -r '.usdtToken' "$DEPLOYMENTS_FILE")"
    UA1="$(jq -r '.usdcToken' "$DEPLOYMENTS_FILE")"
    if [ -z "$UA0" ] || [ "$UA0" = "null" ]; then
        echo "Missing .usdtToken in $DEPLOYMENTS_FILE"
        exit 1
    fi
    if [ -z "$UA1" ] || [ "$UA1" = "null" ]; then
        echo "Missing .usdcToken in $DEPLOYMENTS_FILE"
        exit 1
    fi
    if [ "$UA0" = "$UA1" ]; then
        echo "Refusing to write identical underlyings (both=$UA0). Check $DEPLOYMENTS_FILE"
        exit 1
    fi
    ENV_FILE=".env"
    upsert_env() {
        local key="$1"
        local val="$2"
        # Ensure the key exists exactly once (dotenv loaders can behave unexpectedly with duplicates).
        # Remove any existing lines like:
        # - KEY=...
        # - export KEY=...
        # - KEY = ...
        if [ -f "$ENV_FILE" ]; then
            tmp="${ENV_FILE}.tmp"
            perl -ne "print unless /^\\s*(?:export\\s+)?\\Q${key}\\E\\s*=/;" "$ENV_FILE" > "$tmp"
            mv "$tmp" "$ENV_FILE"
        fi
        echo "${key}=${val}" >> "$ENV_FILE"
    }
    upsert_env "UNDERLYING_ASSET_0" "$UA0"
    upsert_env "UNDERLYING_ASSET_1" "$UA1"
    echo "Wrote UNDERLYING_ASSET_0/1 to ${ENV_FILE}"

# Grant ACM permission for ConfigureOracle (LOCAL/dev)
allow-oracle-configure:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ mode }}" != "LOCAL" ]; then
        echo "allow-oracle-configure is intended for MODE=LOCAL. Skipping."
        exit 0
    fi
    if [ -z "${PRIVATE_KEY:-}" ]; then
        echo "Missing PRIVATE_KEY (required to derive ACCOUNT_TO_PERMIT)"
        exit 1
    fi
    ORACLE_ADDR_FILE="deployments/oracle_deployments/development/addresses.json"
    if [ ! -f "$ORACLE_ADDR_FILE" ]; then
        echo "Missing $ORACLE_ADDR_FILE (run \`just deploy-oracle\` first)"
        exit 1
    fi
    RESILIENT_ORACLE_ADDRESS="$(jq -r '.ResilientOracle_Proxy' "$ORACLE_ADDR_FILE")"
    if [ -z "$RESILIENT_ORACLE_ADDRESS" ] || [ "$RESILIENT_ORACLE_ADDRESS" = "null" ]; then
        echo "Failed to read ResilientOracle_Proxy from $ORACLE_ADDR_FILE"
        exit 1
    fi
    ACCOUNT_TO_PERMIT="$(cast wallet address --private-key "$PRIVATE_KEY")"
    TARGET_ADDRESS="$RESILIENT_ORACLE_ADDRESS"
    FUNCTION_SIG="setTokenConfig(TokenConfig)"
    echo "Granting ACM permission for $ACCOUNT_TO_PERMIT -> $FUNCTION_SIG on $TARGET_ADDRESS"
    TARGET_ADDRESS="$TARGET_ADDRESS" FUNCTION_SIG="$FUNCTION_SIG" ACCOUNT_TO_PERMIT="$ACCOUNT_TO_PERMIT" \
        forge script {{ script_dir }}/admin/ResilientOracleACMPermissions.s.sol:ResilientOracleACMGiveCallPermissionScript \
            --rpc-url {{ rpc_url }} \
            {{ broadcast_flag }} -vvv

# Mint/transfer mock tokens to the LP
mint-mock-tokens:
    forge script {{ script_dir }}/setup/MintMockERC20.s.sol:MintMockERC20Script \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Deploy all core contracts
deploy: deploy-oracle deploy-libraries deploy-contracts

deploy-libraries:
    FOUNDRY_PROFILE=deploy forge script {{ script_dir }}/deploy/DeployLibraries.s.sol:DeployLibraries \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

deploy-contracts:
    #!/usr/bin/env bash
    set -euo pipefail
    # Reload dotenv at runtime (important when `deploy-oracle` just generated/updated `.env` earlier in the same `just deploy` run).
    if [ -f ".env" ]; then
        set -a
        # shellcheck disable=SC1091
        source ".env"
        set +a
    fi

    # validate resilient oracle address is set
    if [ -z "${RESILIENT_ORACLE_ADDRESS:-}" ]; then
        echo "Missing RESILIENT_ORACLE_ADDRESS. Run \`just deploy-oracle\` first (it writes .env) or export RESILIENT_ORACLE_ADDRESS manually."
        exit 1
    fi

    # deploy contracts
    FOUNDRY_PROFILE=deploy forge script {{ script_dir }}/deploy/DeployContracts.s.sol:DeployContracts \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Deploy oracle contracts via Hardhat
deploy-oracle:
    #!/usr/bin/env bash
    set -euo pipefail
    ROOT_DIR="$(pwd)"
    # Normalise MODE so `MODE=live` and `MODE=LIVE` behave identically.
    MODE_ARG="{{ mode }}"
    MODE_NORM="$(printf '%s' "$MODE_ARG" | tr '[:lower:]' '[:upper:]')"
    if [ "$MODE_NORM" = "LOCAL" ]; then
        ORACLE_NETWORK_ARG="development"
    elif [ "{{ network }}" = "ethsepolia" ]; then
        ORACLE_NETWORK_ARG="sepolia"
    elif [ "{{ network }}" = "sepolia" ]; then
        ORACLE_NETWORK_ARG="arbitrumsepolia"
    elif [ "{{ network }}" = "arbitrum" ]; then
        ORACLE_NETWORK_ARG="arbitrumone"
    else
        ORACLE_NETWORK_ARG="{{ network }}"
    fi

    echo "Deploying oracle to network: $ORACLE_NETWORK_ARG"
    cp ../evm/oracle/hardhat.custom.config.ts ../evm/lib/oracle/hardhat.fiet.config.ts
    LIVE_ACM_ADDRESS=""

    # In MODE=LIVE, patch the oracle submodule after it is checked out.
    # This appends a small snippet that allows `LIVE_ACM_ADDRESS` to override `ADDRESSES[network].acm`
    # at runtime, without committing changes inside the submodule.
    if [ "$MODE_NORM" = "LIVE" ]; then
        ORACLE_DEPLOYMENT_CONFIG="${ROOT_DIR}/../evm/lib/oracle/helpers/deploymentConfig.ts"
        ORACLE_DEPLOYMENT_CONFIG_PATCH="${ROOT_DIR}/../evm/oracle/patches/deploymentConfig.live-acm-override.append.ts"
        PATCH_MARKER="FIET_PATCH_LIVE_ACM_OVERRIDE"
        if [ ! -f "$ORACLE_DEPLOYMENT_CONFIG_PATCH" ]; then
            echo "Missing oracle patch snippet: $ORACLE_DEPLOYMENT_CONFIG_PATCH"
            exit 1
        fi
        if ! grep -q "$PATCH_MARKER" "$ORACLE_DEPLOYMENT_CONFIG" 2>/dev/null; then
            echo "Patching oracle deploymentConfig.ts for MODE=LIVE ACM override"
            cat "$ORACLE_DEPLOYMENT_CONFIG_PATCH" >> "$ORACLE_DEPLOYMENT_CONFIG"
        fi
    fi

    if [ "$MODE_NORM" = "LIVE" ]; then
        # In MODE=LIVE, deploy a fresh ACM first and keep its admin role with the deployer EOA.
        # We inject this address into Hardhat config so the downstream oracle deploy uses it.
        # Run the ACM deploy script from the Hardhat project directory (lib/oracle) while keeping the
        # script source checked in under `contracts/evm/oracle/` for easier maintenance.
        ACM_DEPLOY_OUTPUT="$(cd ../evm/lib/oracle && npx --yes hardhat --config ./hardhat.fiet.config.ts run --network "$ORACLE_NETWORK_ARG" ../../oracle/scripts/deploy-live-acm.cjs)"

        LIVE_ACM_ADDRESS="$(printf '%s\n' "$ACM_DEPLOY_OUTPUT" | awk -F= '/^ACM_DEPLOYED_ADDRESS=/{print $2; exit}')"
        if [ -z "$LIVE_ACM_ADDRESS" ]; then
            echo "Failed to deploy LIVE ACM (address not found in hardhat output)"
            echo "$ACM_DEPLOY_OUTPUT"
            exit 1
        fi

        # Validate the deployed ACM actually exists on the target chain before deploying dependent contracts.
        LIVE_ACM_CODE="$(cast code "$LIVE_ACM_ADDRESS" --rpc-url {{ rpc_url }})"
        if [ "$LIVE_ACM_CODE" = "0x" ]; then
            echo "LIVE ACM has no code at $LIVE_ACM_ADDRESS on {{ network }}"
            exit 1
        fi
        echo "Using freshly deployed LIVE ACM: $LIVE_ACM_ADDRESS"
    fi

    cd ../evm/lib/oracle && MODE="$MODE_NORM" LIVE_ACM_ADDRESS="$LIVE_ACM_ADDRESS" \
        npx --yes hardhat --config ./hardhat.fiet.config.ts deploy --network "$ORACLE_NETWORK_ARG" --tags deploy --reset

    # Read from stored files and persist env vars for subsequent Foundry scripts.
    # Hardhat writes deployments to `../evm/deployments/oracle_deployments` (see `contracts/evm/oracle/hardhat.custom.config.ts`).
    ORACLE_DIR="${ROOT_DIR}/../evm/deployments/oracle_deployments/${ORACLE_NETWORK_ARG}"
    RESILIENT_ORACLE_JSON="${ORACLE_DIR}/ResilientOracle_Proxy.json"
    ACM_JSON="${ORACLE_DIR}/AccessControlManager.json"

    # In MODE=LIVE, ACM is pre-deployed outside hardhat-deploy manifests.
    # Write a minimal deployment JSON so existing parsing/export logic remains unchanged.
    if [ "$MODE_NORM" = "LIVE" ] && [ ! -f "$ACM_JSON" ] && [ -n "$LIVE_ACM_ADDRESS" ]; then
        mkdir -p "$ORACLE_DIR"
        jq -n --arg address "$LIVE_ACM_ADDRESS" '{address: $address}' > "$ACM_JSON"
    fi

    if [ ! -f "$RESILIENT_ORACLE_JSON" ]; then
        echo "Expected oracle deployment file not found: $RESILIENT_ORACLE_JSON"
        exit 1
    fi
    if [ ! -f "$ACM_JSON" ]; then
        echo "Expected ACM deployment file not found: $ACM_JSON"
        exit 1
    fi

    RESILIENT_ORACLE_ADDRESS="$(jq -r '.address' "$RESILIENT_ORACLE_JSON")"
    if [ -z "$RESILIENT_ORACLE_ADDRESS" ] || [ "$RESILIENT_ORACLE_ADDRESS" = "null" ]; then
        echo "Failed to read .address from $RESILIENT_ORACLE_JSON"
        exit 1
    fi

    ACCESS_CONTROL_MANAGER="$(jq -r '.address' "$ACM_JSON")"
    if [ -z "$ACCESS_CONTROL_MANAGER" ] || [ "$ACCESS_CONTROL_MANAGER" = "null" ]; then
        echo "Failed to read .address from $ACM_JSON"
        exit 1
    fi

    ENV_FILE="${ROOT_DIR}/.env"
    upsert_env() {
        local key="$1"
        local val="$2"
        # Ensure the key exists exactly once (dotenv loaders can behave unexpectedly with duplicates).
        # Remove any existing lines like:
        # - KEY=...
        # - export KEY=...
        # - KEY = ...
        if [ -f "$ENV_FILE" ]; then
            tmp="${ENV_FILE}.tmp"
            perl -ne "print unless /^\\s*(?:export\\s+)?\\Q${key}\\E\\s*=/;" "$ENV_FILE" > "$tmp"
            mv "$tmp" "$ENV_FILE"
        fi
        echo "${key}=${val}" >> "$ENV_FILE"
    }

    upsert_env "RESILIENT_ORACLE_ADDRESS" "$RESILIENT_ORACLE_ADDRESS"
    upsert_env "ACCESS_CONTROL_MANAGER" "$ACCESS_CONTROL_MANAGER"
    echo "Wrote RESILIENT_ORACLE_ADDRESS=${RESILIENT_ORACLE_ADDRESS} to ${ENV_FILE}"
    echo "Wrote ACCESS_CONTROL_MANAGER=${ACCESS_CONTROL_MANAGER} to ${ENV_FILE}"

    # Keep a local copy under `./deployments/` for convenience/debugging (overwrites any stale file).
    OUT_DIR="${ROOT_DIR}/deployments/oracle_deployments/${ORACLE_NETWORK_ARG}"
    mkdir -p "$OUT_DIR"

    # Copy per-contract deployment files (useful for deeper debugging).
    for f in \
      AccessControlManager.json \
      VAI.json \
      DefaultProxyAdmin.json \
      BoundValidator_Implementation.json \
      BoundValidator_Proxy.json \
      ResilientOracle_Implementation.json \
      ResilientOracle_Proxy.json \
      ChainlinkOracle_Implementation.json \
      ChainlinkOracle_Proxy.json; do
        if [ -f "${ORACLE_DIR}/${f}" ]; then
            cp "${ORACLE_DIR}/${f}" "${OUT_DIR}/${f}"
        fi
    done

    # Write a single address-book JSON for scripts/tools.
    jq -n \
      --arg AccessControlManager "$(jq -r '.address' "${ORACLE_DIR}/AccessControlManager.json")" \
      --arg VAI "$(jq -r '.address' "${ORACLE_DIR}/VAI.json")" \
      --arg DefaultProxyAdmin "$(jq -r '.address' "${ORACLE_DIR}/DefaultProxyAdmin.json")" \
      --arg BoundValidator_Implementation "$(jq -r '.address' "${ORACLE_DIR}/BoundValidator_Implementation.json")" \
      --arg BoundValidator_Proxy "$(jq -r '.address' "${ORACLE_DIR}/BoundValidator_Proxy.json")" \
      --arg ResilientOracle_Implementation "$(jq -r '.address' "${ORACLE_DIR}/ResilientOracle_Implementation.json")" \
      --arg ResilientOracle_Proxy "$(jq -r '.address' "${ORACLE_DIR}/ResilientOracle_Proxy.json")" \
      --arg ChainlinkOracle_Implementation "$(jq -r '.address' "${ORACLE_DIR}/ChainlinkOracle_Implementation.json")" \
      --arg ChainlinkOracle_Proxy "$(jq -r '.address' "${ORACLE_DIR}/ChainlinkOracle_Proxy.json")" \
      '{
        AccessControlManager: $AccessControlManager,
        VAI: $VAI,
        DefaultProxyAdmin: $DefaultProxyAdmin,
        BoundValidator_Implementation: $BoundValidator_Implementation,
        BoundValidator_Proxy: $BoundValidator_Proxy,
        ResilientOracle_Implementation: $ResilientOracle_Implementation,
        ResilientOracle_Proxy: $ResilientOracle_Proxy,
        ChainlinkOracle_Implementation: $ChainlinkOracle_Implementation,
        ChainlinkOracle_Proxy: $ChainlinkOracle_Proxy
      }' > "${OUT_DIR}/addresses.json"

    echo "Wrote oracle address book to ${OUT_DIR}/addresses.json"

    # Also write DefaultProxyAdmin "public key" (address) as a simple text file.
    DEFAULT_PROXY_ADMIN="$(jq -r '.address' "${ORACLE_DIR}/DefaultProxyAdmin.json")"
    echo "${DEFAULT_PROXY_ADMIN}" > "${OUT_DIR}/DefaultProxyAdmin.address"
    echo "Wrote DefaultProxyAdmin address to ${OUT_DIR}/DefaultProxyAdmin.address"

# Configure the local resilient oracle (enables MAIN oracle + sets mock prices for default CreateMarket pair)
configure-oracle:
    #!/usr/bin/env bash
    set -euo pipefail

    # Reload dotenv at runtime (important when earlier recipes updated `.env` within the same `just dev` run).
    if [ -f ".env" ]; then
        set -a
        # shellcheck disable=SC1091
        source ".env"
        set +a
    fi

    # In LOCAL mode, derive missing values from the deployment artefacts produced by earlier steps.
    if [ "{{ mode }}" = "LOCAL" ]; then
        ORACLE_ADDR_FILE="deployments/oracle_deployments/development/addresses.json"
        if [ -f "$ORACLE_ADDR_FILE" ]; then
            if [ -z "${RESILIENT_ORACLE_ADDRESS:-}" ] || [ "${RESILIENT_ORACLE_ADDRESS:-}" = "null" ]; then
                export RESILIENT_ORACLE_ADDRESS
                RESILIENT_ORACLE_ADDRESS="$(jq -r '.ResilientOracle_Proxy' "$ORACLE_ADDR_FILE")"
            fi
            if [ -z "${MAIN_ORACLE_ADDRESS:-}" ] || [ "${MAIN_ORACLE_ADDRESS:-}" = "null" ]; then
                export MAIN_ORACLE_ADDRESS
                MAIN_ORACLE_ADDRESS="$(jq -r '.ChainlinkOracle_Proxy' "$ORACLE_ADDR_FILE")"
            fi
        fi

        DEPLOYMENTS_FILE="deployments/local_{{ network }}_deployments.json"
        if [ -f "$DEPLOYMENTS_FILE" ]; then
            if [ -z "${UNDERLYING_ASSET_0:-}" ] || [ "${UNDERLYING_ASSET_0:-}" = "null" ]; then
                export UNDERLYING_ASSET_0
                UNDERLYING_ASSET_0="$(jq -r '.usdtToken' "$DEPLOYMENTS_FILE")"
            fi
            if [ -z "${UNDERLYING_ASSET_1:-}" ] || [ "${UNDERLYING_ASSET_1:-}" = "null" ]; then
                export UNDERLYING_ASSET_1
                UNDERLYING_ASSET_1="$(jq -r '.usdcToken' "$DEPLOYMENTS_FILE")"
            fi
        fi
    fi

    if [ -z "${RESILIENT_ORACLE_ADDRESS:-}" ] || [ "$RESILIENT_ORACLE_ADDRESS" = "null" ]; then
        echo "Missing RESILIENT_ORACLE_ADDRESS. Run \`just deploy-oracle\` first (it writes .env) or export RESILIENT_ORACLE_ADDRESS manually."
        exit 1
    fi

    # Fail fast with a clear message if the address is stale (EOA/empty) on the current RPC.
    RESILIENT_CODE="$(cast code "$RESILIENT_ORACLE_ADDRESS" --rpc-url {{ rpc_url }})"
    if [ "$RESILIENT_CODE" = "0x" ]; then
        echo "RESILIENT_ORACLE_ADDRESS has no code on {{ rpc_url }}: $RESILIENT_ORACLE_ADDRESS"
        echo "This usually means a stale env var was used or Anvil was restarted. Re-run \`just deploy-oracle\` (or \`just dev\`) against the current Anvil."
        exit 1
    fi

    if [ -n "${MAIN_ORACLE_ADDRESS:-}" ] && [ "${MAIN_ORACLE_ADDRESS:-}" != "null" ]; then
        MAIN_CODE="$(cast code "$MAIN_ORACLE_ADDRESS" --rpc-url {{ rpc_url }})"
        if [ "$MAIN_CODE" = "0x" ]; then
            echo "MAIN_ORACLE_ADDRESS has no code on {{ rpc_url }}: $MAIN_ORACLE_ADDRESS"
            echo "Re-run \`just deploy-oracle\` (or \`just dev\`) against the current Anvil, or export MAIN_ORACLE_ADDRESS to a deployed oracle."
            exit 1
        fi
    fi

    forge script {{ script_dir }}/setup/ConfigureOracle.s.sol:ConfigureOracleScript \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Read deployment information
read-deployment:
    forge script {{ script_dir }}/ReadDeployment.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

