# === Development Workflows ===

# Complete development setup (setup create3, deploy tokens, configure underlyings, deploy contracts, configure oracle, create market)
# Include ACM admin handoff so allow-oracle-configure can grant permissions via GlobalConfig.proxyCall.
dev: setup-create3 deploy-tokenA deploy-tokenB set-underlyings deploy admin-acm-transfer-admin-to-globalconfig allow-oracle-configure configure-oracle create-market

# Production Steps:
# 1. deploy-oracle
# 2. Simulate: deploy-libraries
# 3. Deploy: deploy-libraries
# 4. just deploy-contracts, IF ARB SEPOLIA prefix with FOUNDRY_PROFILE=deploy-arbitrum-sepolia
#
# ACM / oracle ownership handoff
# 5. Oracle stack → GlobalConfig: with NETWORK matching core deployments, addresses default from
#    deployments/oracle_deployments/<oracle-namespace>/addresses.json (see ORACLE.md). Optional overrides:
#    RESILIENT_ORACLE_ADDRESS, BOUND_VALIDATOR_ADDRESS, MAIN_ORACLE_ADDRESS, ORACLE_PROXY_ADMIN_ADDRESS
#    (oracle DefaultProxyAdmin contract — never GlobalConfig). Legacy: DEFAULT_PROXY_ADMIN_ADDRESS.
#    Example: MODE=LIVE NETWORK=arbitrum BROADCAST=true PRIVATE_KEY=... just admin-oracle-transfer-to-globalconfig
# 6 ACM Call Permissions:
# See examples in ORACLE.md
#
# Required ACM call permissions (methodSignature strings):
# - ResilientOracle token config (what `just configure-oracle` does):
#   - target: `ResilientOracle_Proxy`
#   - methodSignature: "setTokenConfig(TokenConfig)"
#   - accountToPermit: the EOA running `just configure-oracle` (derived from `PRIVATE_KEY`), OR `GlobalConfig`
#     if you execute config via `GlobalConfig.proxyCall(...)`.
#
# - MAIN oracle feed wiring (needed for MODE!=LOCAL before enabling MAIN in ResilientOracle):
#   - target: `ChainlinkOracle_Proxy` (or whichever MAIN oracle you are using)
#   - methodSignature: "setTokenConfig((address,address,uint256))"  # (asset, feed, maxStalePeriod)
#
# Market Creation
# 7. ORACLE_CONFIG_FILE=ethsepolia.json just admin-oracle-configure-assets OR configure-oracle
# 8. create-market

# === Build ===

# Build all Solidity contracts
build:
    forge build

# === Fork ===

# Start Anvil fork for local development
# Pass extra anvil args after --, e.g. just fork -- --fork-block-number 21000000
# Or set BLOCK_NUMBER env var e.g BLOCK_NUMBER=8891589 just fork
fork:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "⛽ Starting anvil forked from Network: {{ network }}..."
    CHAIN_ID_ARG="${CHAIN_ID:-31337}"
    # Defensive: support quoted dotenv values like CHAIN_ID="421614"
    CHAIN_ID_ARG="${CHAIN_ID_ARG%\"}"
    CHAIN_ID_ARG="${CHAIN_ID_ARG#\"}"
    if [ -n "${BLOCK_NUMBER:-}" ]; then
        echo "  Forking at block: $BLOCK_NUMBER"
        exec anvil --fork-url {{ fork_source_rpc }} --port {{ anvil_port }} --chain-id "$CHAIN_ID_ARG" \
            --fork-block-number "$BLOCK_NUMBER" "$@"
    else
        exec anvil --fork-url {{ fork_source_rpc }} --port {{ anvil_port }} --chain-id "$CHAIN_ID_ARG" "$@"
    fi

# === Setup ===

# Setup CREATE3Factory
# - MODE=LOCAL: installs CREATE3Factory code at the canonical address via anvil_setCode
# - MODE!=LOCAL: if the canonical factory is missing, deploys a non-canonical factory and
#   writes its address to `deployments/create3_factory_${NETWORK}.address` (use CREATE3_FACTORY to override)
setup-create3:
    #!/usr/bin/env bash
    set -euo pipefail
    ADDR="0x9fBB3DF7C40Da2e5A0dE984fFE2CCB7C47cd0ABf"
    echo "Checking CREATE3Factory code at $ADDR via {{ rpc_url }} ..."
    EXISTING_CODE="$(cast code "$ADDR" --rpc-url {{ rpc_url }})"
    if [ "$EXISTING_CODE" != "0x" ]; then
        echo "CREATE3Factory already present at $ADDR (codesize > 0)."
        exit 0
    fi
    if [ "{{ mode }}" = "LOCAL" ]; then
        echo "CREATE3Factory not found. Installing bytecode with anvil_setCode..."
        BYTECODE="$(forge inspect CREATE3Factory deployedBytecode)"
        cast rpc anvil_setCode "$ADDR" "$BYTECODE" --rpc-url {{ rpc_url }}
        # Verify
        NEW_CODE="$(cast code "$ADDR" --rpc-url {{ rpc_url }})"
        if [ "$NEW_CODE" = "0x" ]; then
            echo "Failed to install CREATE3Factory bytecode at $ADDR"
            exit 1
        fi
        echo "CREATE3Factory installed at $ADDR"
        exit 0
    fi

    if [ "{{ broadcast }}" != "true" ]; then
        echo "CREATE3Factory is missing at canonical address $ADDR on MODE={{ mode }}."
        echo "Re-run with BROADCAST=true to deploy a CREATE3Factory and then set CREATE3_FACTORY for subsequent scripts."
        exit 1
    fi

    echo "CREATE3Factory missing at canonical address on MODE={{ mode }}."
    echo "Deploying a CREATE3Factory and writing its address to deployments/create3_factory_{{ network }}.address ..."
    forge script {{ script_dir }}/deploy/DeployCreate3Factory.s.sol:DeployCreate3Factory \
        --rpc-url {{ rpc_url }} \
        --broadcast -vvv

    OUT_FILE="deployments/create3_factory_{{ network }}.address"
    if [ ! -f "$OUT_FILE" ]; then
        echo "Expected output file $OUT_FILE not found."
        exit 1
    fi
    DEPLOYED_ADDR="$(cat "$OUT_FILE" | tr -d '\n' | tr -d '\r')"
    if [ -z "$DEPLOYED_ADDR" ]; then
        echo "Empty deployed address in $OUT_FILE"
        exit 1
    fi
    echo "Deployed CREATE3Factory at: $DEPLOYED_ADDR"
    echo ""
    echo "Next:"
    echo "  export CREATE3_FACTORY=$DEPLOYED_ADDR"
    echo "  (or add it to your dotenv file for contracts/evm-scripts)"

# Predict the deterministic CREATE3 GlobalConfig address (salt: keccak256("GlobalConfig-v1"))
predict-globalconfig:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "${PRIVATE_KEY:-}" ]; then
        echo "Missing PRIVATE_KEY (required to derive deployer namespace for CREATE3)"
        exit 1
    fi

    CREATE3_FACTORY_FILE="deployments/create3_factory_{{ network }}.address"
    if [ -n "${CREATE3_FACTORY:-}" ]; then
        FACTORY="$CREATE3_FACTORY"
    elif [ "{{ mode }}" = "LOCAL" ]; then
        FACTORY="0x9fBB3DF7C40Da2e5A0dE984fFE2CCB7C47cd0ABf"
    elif [ -f "$CREATE3_FACTORY_FILE" ] && [ -s "$CREATE3_FACTORY_FILE" ]; then
        FACTORY="$(tr -d '\n\r' < "$CREATE3_FACTORY_FILE" | head -n1)"
    elif [ "{{ network }}" = "sepolia" ]; then
        FACTORY="0x0EC3715467915Cbd7355A6B111510e4a09D9ccC0"
    else
        FACTORY="0x9fBB3DF7C40Da2e5A0dE984fFE2CCB7C47cd0ABf"
    fi
    export CREATE3_FACTORY="$FACTORY"

    DEPLOYER_ADDR="$(cast wallet address --private-key "$PRIVATE_KEY")"
    SALT="$(cast keccak "GlobalConfig-v1")"
    PREDICTED_ADDR="$(cast call "$FACTORY" "getDeployed(address,bytes32)(address)" "$DEPLOYER_ADDR" "$SALT" --rpc-url {{ rpc_url }} | tr -d '\n' | tr -d '\r')"

    echo "CREATE3 factory: $FACTORY"
    echo "Deployer:       $DEPLOYER_ADDR"
    echo "Salt:           $SALT"
    echo "GlobalConfig:   $PREDICTED_ADDR"

