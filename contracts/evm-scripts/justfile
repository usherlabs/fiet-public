# Persist UNDERLYING_ASSET_0/1 based on mock deployments
set-underlyings:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ mode }}" != "LOCAL" ]; then
        echo "set-underlyings is intended for MODE=LOCAL. Skipping."
        exit 0
    fi
    DEPLOYMENTS_FILE="deployments/local_{{ network }}_deployments.json"
    if [ ! -f "$DEPLOYMENTS_FILE" ]; then
        echo "Expected $DEPLOYMENTS_FILE not found. Run \`just deploy-tokenA\` and \`just deploy-tokenB\` first."
        exit 1
    fi
    UA0="$(jq -r '.usdtToken' "$DEPLOYMENTS_FILE")"
    UA1="$(jq -r '.usdcToken' "$DEPLOYMENTS_FILE")"
    if [ -z "$UA0" ] || [ "$UA0" = "null" ]; then
        echo "Missing .usdtToken in $DEPLOYMENTS_FILE"
        exit 1
    fi
    if [ -z "$UA1" ] || [ "$UA1" = "null" ]; then
        echo "Missing .usdcToken in $DEPLOYMENTS_FILE"
        exit 1
    fi
    if [ "$UA0" = "$UA1" ]; then
        echo "Refusing to write identical underlyings (both=$UA0). Check $DEPLOYMENTS_FILE"
        exit 1
    fi
    ENV_FILE=".env"
    upsert_env() {
        local key="$1"
        local val="$2"
        # Ensure the key exists exactly once (dotenv loaders can behave unexpectedly with duplicates).
        # Remove any existing lines like:
        # - KEY=...
        # - export KEY=...
        # - KEY = ...
        if [ -f "$ENV_FILE" ]; then
            tmp="${ENV_FILE}.tmp"
            perl -ne "print unless /^\\s*(?:export\\s+)?\\Q${key}\\E\\s*=/;" "$ENV_FILE" > "$tmp"
            mv "$tmp" "$ENV_FILE"
        fi
        echo "${key}=${val}" >> "$ENV_FILE"
    }
    upsert_env "UNDERLYING_ASSET_0" "$UA0"
    upsert_env "UNDERLYING_ASSET_1" "$UA1"
    echo "Wrote UNDERLYING_ASSET_0/1 to ${ENV_FILE}"

# Grant ACM permission for ConfigureOracle (LOCAL/dev)
allow-oracle-configure:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ mode }}" != "LOCAL" ]; then
        echo "allow-oracle-configure is intended for MODE=LOCAL. Skipping."
        exit 0
    fi
    if [ -z "${PRIVATE_KEY:-}" ]; then
        echo "Missing PRIVATE_KEY (required to derive ACCOUNT_TO_PERMIT)"
        exit 1
    fi
    ORACLE_ADDR_FILE="deployments/oracle_deployments/development/addresses.json"
    if [ ! -f "$ORACLE_ADDR_FILE" ]; then
        echo "Missing $ORACLE_ADDR_FILE (run \`just deploy-oracle\` first)"
        exit 1
    fi
    RESILIENT_ORACLE_ADDRESS="$(jq -r '.ResilientOracle_Proxy' "$ORACLE_ADDR_FILE")"
    if [ -z "$RESILIENT_ORACLE_ADDRESS" ] || [ "$RESILIENT_ORACLE_ADDRESS" = "null" ]; then
        echo "Failed to read ResilientOracle_Proxy from $ORACLE_ADDR_FILE"
        exit 1
    fi
    ACCOUNT_TO_PERMIT="$(cast wallet address --private-key "$PRIVATE_KEY")"
    TARGET_ADDRESS="$RESILIENT_ORACLE_ADDRESS"
    FUNCTION_SIG="setTokenConfig(TokenConfig)"
    echo "Granting ACM permission for $ACCOUNT_TO_PERMIT -> $FUNCTION_SIG on $TARGET_ADDRESS"
    TARGET_ADDRESS="$TARGET_ADDRESS" FUNCTION_SIG="$FUNCTION_SIG" ACCOUNT_TO_PERMIT="$ACCOUNT_TO_PERMIT" \
        forge script {{ script_dir }}/admin/ResilientOracleACMPermissions.s.sol:ResilientOracleACMGiveCallPermissionScript \
            --rpc-url {{ rpc_url }} \
            {{ broadcast_flag }} -vvv

# Mint/transfer mock tokens to the LP
mint-mock-tokens:
