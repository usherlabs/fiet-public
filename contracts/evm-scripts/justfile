    forge script {{ script_dir }}/setup/MockERC20.s.sol:TokenScriptUSDC \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Mint/transfer mock tokens to the LP
mint-mock-tokens:
    forge script {{ script_dir }}/setup/MintMockERC20.s.sol:MintMockERC20Script \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Deploy all core contracts
deploy: deploy-oracle deploy-libraries deploy-contracts

deploy-libraries:
    FOUNDRY_PROFILE=deploy forge script {{ script_dir }}/deploy/DeployLibraries.s.sol:DeployLibraries \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

deploy-contracts:
    #!/usr/bin/env bash
    set -euo pipefail
    # Reload dotenv at runtime (important when `deploy-oracle` just generated/updated `.env` earlier in the same `just deploy` run).
    if [ -f ".env" ]; then
        set -a
        # shellcheck disable=SC1091
        source ".env"
        set +a
    fi

    # validate resilient oracle address is set
    if [ -z "${RESILIENT_ORACLE_ADDRESS:-}" ]; then
        echo "Missing RESILIENT_ORACLE_ADDRESS. Run \`just deploy-oracle\` first (it writes .env) or export RESILIENT_ORACLE_ADDRESS manually."
        exit 1
    fi

    # deploy contracts
    FOUNDRY_PROFILE=deploy forge script {{ script_dir }}/deploy/DeployContracts.s.sol:DeployContracts \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

