# === Market Operations ===

# Create a new market
create-market:
    #!/usr/bin/env bash
    set -euo pipefail

    # Reload dotenv at runtime (important when earlier recipes updated `.env` within the same `just dev` run).
    if [ -f ".env" ]; then
        set -a
        # shellcheck disable=SC1091
        source ".env"
        set +a
    fi

    # In LOCAL mode, fall back to the token deployment artefact if underlyings are not set.
    if [ "{{ mode }}" = "LOCAL" ]; then
        DEPLOYMENTS_FILE="deployments/local_{{ network }}_deployments.json"
        if [ -f "$DEPLOYMENTS_FILE" ]; then
            if [ -z "${UNDERLYING_ASSET_0:-}" ] || [ "${UNDERLYING_ASSET_0:-}" = "null" ]; then
                export UNDERLYING_ASSET_0
                UNDERLYING_ASSET_0="$(jq -r '.usdtToken' "$DEPLOYMENTS_FILE")"
            fi
            if [ -z "${UNDERLYING_ASSET_1:-}" ] || [ "${UNDERLYING_ASSET_1:-}" = "null" ]; then
                export UNDERLYING_ASSET_1
                UNDERLYING_ASSET_1="$(jq -r '.usdcToken' "$DEPLOYMENTS_FILE")"
            fi
        fi
    fi

    forge script {{ script_dir }}/CreateMarket.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Pause market operations
pause-market:
    forge script {{ script_dir }}/PauseMarket.s.sol \
