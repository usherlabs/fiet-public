# Validate hard-linked Echidna library addresses are up to date.
validate-fuzz-libs:
  FOUNDRY_PROFILE=echidna forge script \
    test/fuzz/script/ValidateEchidnaLinkedLibs.s.sol:ValidateEchidnaLinkedLibs \
    --sig "run()"