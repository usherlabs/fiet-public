## Fiet Protocol (EVM) - developer commands
#
# This Justfile provides stable entrypoints for running the Medusa-backed fuzz
# harness suite. The Solidity properties intentionally retain their legacy
# `echidna_*` names so the migration stays focused on tooling rather than broad
# contract churn.
#
# Usage:
#   just --list
#   just fuzz
#   just medusa file=test/fuzz/invariants/LCC01.sol contract=LCC01
#

set export := true

[private]
default:
    @just --list --unsorted

# ----------------------------
# Medusa (fuzzing) helpers
# ----------------------------
# Generic Medusa runner wrapper.
# Pass through extra args via `--`, e.g.:
#
# just medusa file=test/fuzz/invariants/LCC01.sol contract=LCC01 -- --test-limit 20000
# MEDUSA_CORPUS_DIR=artifacts/medusa-local just medusa file=... contract=...
medusa file contract config="medusa.json" *args:
    FOUNDRY_PROFILE=medusa FOUNDRY_OUT_DIR=out-medusa \
      sh ./scripts/medusa.sh --file {{ file }} --contract {{ contract }} --config {{ config }} {{ args }}

