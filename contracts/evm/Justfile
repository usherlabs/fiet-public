# Targeted regression harnesses that complement canonical `test/fuzz/invariants/*`
# coverage. These focus on specific behavioural paths and historical bug surfaces.
fuzz-regressions:
    @just medusa-wrapwith
    @just medusa-lcc-queue-netting
    @just medusa-confirmtake-callback
    # MKT-05 remains authoritatively gated by `invariant-evidence-foundry`;
    # this Medusa target is retained as a lightweight regression/drift check.
    @just medusa-mkt-05

# Short Medusa campaign that preserves coverage-guided corpus artifacts in-tree.
# Uses one canonical invariant, one accounting path, and one legacy-named
# regression harness to catch migration drift without running the full suite.
medusa-coverage-smoke dir="artifacts/medusa-smoke" config="medusa.json":
    rm -rf {{ dir }}
    mkdir -p {{ dir }}
    @just validate-fuzz-libs
    MEDUSA_CORPUS_DIR={{ dir }} just medusa test/fuzz/invariants/LCC01.sol LCC01 {{ config }} -- --test-limit 50 --seq-len 5
    MEDUSA_CORPUS_DIR={{ dir }} just medusa test/fuzz/invariants/COMMIT01.sol COMMIT01 {{ config }} -- --test-limit 50 --seq-len 5
    MEDUSA_CORPUS_DIR={{ dir }} just medusa test/fuzz/LiquidityHubWrapWithQueueEchidnaTest.sol LiquidityHubWrapWithQueueEchidnaTest {{ config }} -- --test-limit 50 --seq-len 5
    find {{ dir }} -maxdepth 3 -type f | sort

