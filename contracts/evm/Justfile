# Validate fuzz linked-library wiring and deployment preconditions.
validate-fuzz-libs:
    python3 scripts/validate_fuzz_lib_config.py
    FOUNDRY_PROFILE=medusa forge script \
      test/fuzz/script/ValidateEchidnaLinkedLibs.s.sol:ValidateEchidnaLinkedLibs \
      --sig "run()"
    FOUNDRY_PROFILE=medusa forge script \
      test/fuzz/script/SmokeEchidnaLinkedLibs.s.sol:SmokeEchidnaLinkedLibs \
      --sig "run()"

# Apply manifest and iterate until linked initcode matches (updates txt when stable).
recompute-fuzz-lib-addrs:
    python3 scripts/validate_fuzz_lib_config.py converge

# Print machine-readable lines for the manifest file (paste into echidna-linked-libs.txt).
print-fuzz-lib-manifest:
    FOUNDRY_PROFILE=medusa forge script \
      test/fuzz/script/ValidateEchidnaLinkedLibs.s.sol:ValidateEchidnaLinkedLibs \
      --sig "printManifest()"

# Print human-readable CREATE2 outputs and copy-paste blocks (verbose).
print-fuzz-lib-addrs:
    FOUNDRY_PROFILE=medusa forge script \
      test/fuzz/script/ValidateEchidnaLinkedLibs.s.sol:ValidateEchidnaLinkedLibs \
      --sig "printComputed()"
