# Full invariant suite entrypoint for CI:
# - all Medusa property harnesses
# - Foundry evidence tests referenced in fuzz README
fuzz-invariants:
    @just fuzz
    @just invariant-evidence-foundry

invariant-evidence-foundry:
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/DeltaDesignStatements.t.sol
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/AuthSeizeInvariants.t.sol
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/VTSOrchestratorInvariantRegressions.t.sol
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/MarketFactory.t.sol --match-test testFuzz_prepareMarketLiquidity_revertsWhenDifferentCurrencyInFlight
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/MarketFactory.t.sol --match-test test_prepareMarketLiquidity_sameLccSync_restoresAfterNestedErc20Sync
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/MarketFactory.t.sol --match-test test_prepareMarketLiquidity_sameLccSync_nativeUnderlying_clearsAndRestores
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/MarketFactory.t.sol --match-test testFuzz_createMarket_corePairOrderingMatchesStored
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/MarketFactory.t.sol --match-test testFuzz_createMarket_revertsWhenCorePoolAlreadyExists
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/ProxyHook.t.sol --match-test 'testFuzz_swap_exactOutput_.*_revertsWhenRequestedExceedsImmediateLiquidity'
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/ProxyHook.t.sol --match-test test_proxySwap_exactInput_keepsProxySlot0Unchanged
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/ProxyHook.t.sol --match-test test_proxySwap_exactOutput_keepsProxySlot0Unchanged
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/ProxyHook.t.sol --match-test test_proxySwap_exactInput_oneForZero_keepsProxySlot0Unchanged
    FOUNDRY_PROFILE=debug forge test -vvv --match-path test/ProxyHook.t.sol --match-test test_proxySwap_exactOutput_oneForZero_keepsProxySlot0Unchanged

