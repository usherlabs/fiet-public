#!/usr/bin/env bash
set -euo pipefail

# Run Foundry/Forge with the project's debug profile by default.
#
# Usage (from repo root):
#   ./contracts/evm/forge-debug test -vvv
#   ./contracts/evm/forge-debug test --match-path 'test/VTSOrchestrator*.t.sol'
#
# Usage (from contracts/evm):
#   ./forge-debug test -vvv
#
# Notes:
# - Always runs from this directory (the Foundry project root).
# - Defaults `FOUNDRY_PROFILE=debug` unless already set by the caller.

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ ! -f "$HERE/foundry.toml" ]]; then
  echo "ERROR: expected foundry.toml at: $HERE/foundry.toml" >&2
  exit 2
fi

export FOUNDRY_PROFILE="${FOUNDRY_PROFILE:-debug}"

cd "$HERE"
exec forge "$@"


