# Fiet Protocol - Solidity Development Commands
# Run `just` or `just help` to see available commands

set dotenv-load
set export

# === Submodules ===
mod exp "exp/justfile"

# === Configuration ===
mode := env_var_or_default("MODE", "LOCAL")
network := env_var_or_default("NETWORK", "sepolia")
broadcast := env_var_or_default("BROADCAST", "false")
anvil_port := "8545"
anvil_fork_url := "http://localhost:" + anvil_port
script_dir := "script"

# Computed values
fork_source_rpc := if network == "sepolia" {
    env_var("ARB_SEPOLIA_RPC_URL")
} else if network == "arbitrum" {
    env_var("ARB_MAINNET_RPC_URL")
} else if network == "ethsepolia" {
    env_var("ETH_SEPOLIA_RPC_URL")
} else {
    error("Invalid NETWORK value: " + network + ". Must be sepolia, arbitrum, or ethsepolia")
}

rpc_url := if mode == "LOCAL" { anvil_fork_url } else { fork_source_rpc }
deployments := "deployments/" + network + "_deployments.json"
broadcast_flag := if broadcast == "true" { "--broadcast" } else { "" }

# TODO: Solve etherscan issue
verify_flags := ""

# === Help ===

# Show all available commands
[private]
default:
    @just --list --unsorted

