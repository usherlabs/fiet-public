# === Development Workflows ===

# Complete development setup (setup create3, deploy tokens, contracts, create market)
dev: setup-create3 deploy-tokenA deploy-tokenB deploy create-market

# E2E flow: deploy everything and test swap
# Note: Make sure fork is running and wallet has ETH, WETH, and USDC
e2e: deploy-tokenA deploy-tokenB deploy create-market add-liquidity swap

# === Build ===

# Build all Solidity contracts
build:
    forge build

# === Fork ===

# Start Anvil fork for local development
fork:
    @echo "⛽ Starting anvil forked from Network: {{ network }}..."
    anvil --fork-url {{ fork_source_rpc }} --port {{ anvil_port }}

# === Setup ===

# Setup CREATE3Factory for local development (etch at canonical address)
setup-create3:
    forge script {{ script_dir }}/setup/SetupCreate3Factory.s.sol:SetupCreate3Factory \
        --rpc-url {{ rpc_url }} \
        --broadcast -vvv

fork-and-setup: fork setup-create3

# === Deployments ===

# Deploy USDT mock token
deploy-tokenA:
    forge script {{ script_dir }}/setup/MockERC20.s.sol:TokenScriptUSDT \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Deploy USDC mock token
deploy-tokenB:
    forge script {{ script_dir }}/setup/MockERC20.s.sol:TokenScriptUSDC \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# Deploy all core contracts
deploy: deploy-oracle deploy-libraries deploy-contracts

deploy-libraries:
    forge script {{ script_dir }}/deploy/DeployLibraries.s.sol:DeployLibraries \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

deploy-contracts:
    forge script {{ script_dir }}/deploy/DeployContracts.s.sol:DeployContracts \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Deploy oracle contracts via Hardhat
deploy-oracle:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{ mode }}" = "LOCAL" ]; then
        ORACLE_NETWORK_ARG="development"
    elif [ "{{ network }}" = "ethsepolia" ]; then
        ORACLE_NETWORK_ARG="sepolia"
    elif [ "{{ network }}" = "sepolia" ]; then
        ORACLE_NETWORK_ARG="arbitrumsepolia"
    elif [ "{{ network }}" = "arbitrum" ]; then
        ORACLE_NETWORK_ARG="arbitrumone"
    else
        ORACLE_NETWORK_ARG="{{ network }}"
    fi
    echo "Deploying oracle to network: $ORACLE_NETWORK_ARG"
    cp ./oracle/hardhat.custom.config.ts ./lib/oracle/hardhat.fiet.config.ts
    cd lib/oracle && npx hardhat --config ./hardhat.fiet.config.ts deploy --network "$ORACLE_NETWORK_ARG" --tags deploy --reset

# Read deployment information
read-deployment:
    forge script {{ script_dir }}/ReadDeployment.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} {{ verify_flags }} -vvv

# === Market Operations ===

# Create a new market
create-market:
    forge script {{ script_dir }}/CreateMarket.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Pause market operations
pause-market:
    forge script {{ script_dir }}/PauseMarket.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Transfer ownership
transfer-ownership:
    forge script {{ script_dir }}/TransferOwnership.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Add liquidity to market
add-liquidity:
    forge script {{ script_dir }}/AddLiquidity.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Remove liquidity from market
remove-liquidity:
    forge script {{ script_dir }}/RemoveLiquidity.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Execute a swap
swap:
    forge script {{ script_dir }}/SwapV4.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# Unwrap all LCC tokens
unwrap-all:
    forge script {{ script_dir }}/UnwrapLCC.s.sol \
        --rpc-url {{ rpc_url }} \
        {{ broadcast_flag }} -vvv

# === Quality & Security ===

# Install project dependencies
install-deps:
    yarn install

# Run linting checks
lint:
    yarn run lint

# Fix linting issues
lint-fix:
    yarn run lint:fix

# Format code
format:
    yarn run format

# Check code formatting
format-check:
    yarn run format:check

# Run security analysis
security:
    yarn run security

# Run all quality checks (format, lint, security)
quality: format-check lint security

# === CLI Utilities ===

# Read proxy PoolId from Core PoolId
core-to-proxy core_pool_id:
    #!/usr/bin/env bash
    set -euo pipefail
    ADDRESS=$(jq -r '.marketFactory' {{ deployments }})
    echo "Reading coreToProxy for CORE_POOL_ID={{ core_pool_id }} on {{ network }} via $ADDRESS"
    cast call "$ADDRESS" "coreToProxy(bytes32)(bytes32)" {{ core_pool_id }} --rpc-url {{ rpc_url }}

# Read hook address from Proxy PoolId
proxy-to-hook proxy_pool_id:
    #!/usr/bin/env bash
    set -euo pipefail
    ADDRESS=$(jq -r '.marketFactory' {{ deployments }})
    echo "Reading proxyToHook for PROXY_POOL_ID={{ proxy_pool_id }} on {{ network }} via $ADDRESS"
    cast call "$ADDRESS" "proxyToHook(bytes32)(address)" {{ proxy_pool_id }} --rpc-url {{ rpc_url }}
