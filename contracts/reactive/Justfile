## Fiet Protocol (Reactive) - developer commands

set dotenv-load := true
set export := true

reactive_rpc := env_var_or_default("REACTIVE_RPC", "")
protocol_rpc := env_var_or_default("PROTOCOL_RPC", "")
broadcast := env_var_or_default("BROADCAST", "false")
broadcast_flag := if broadcast == "true" { "--broadcast" } else { "" }

[private]
default:
    @just --list --unsorted

[private]
require-reactive-rpc:
    @if [ -z "$REACTIVE_RPC" ]; then echo "Missing REACTIVE_RPC" >&2; exit 1; fi

[private]
require-protocol-rpc:
    @if [ -z "$PROTOCOL_RPC" ]; then echo "Missing PROTOCOL_RPC" >&2; exit 1; fi

# ----------------------------
# Build & test

# ----------------------------
build:
    forge build

test:
    forge test

local-simulation:
    forge test --match-contract HubRSCPseudoE2ETest

# ----------------------------
# Deploy scripts

# ----------------------------
deploy-mock-liquidity-hub: require-protocol-rpc
    forge script scripts/_mocks/DeployMockLiquidityHub.s.sol:DeployMockLiquidityHub --rpc-url {{ protocol_rpc }} {{ broadcast_flag }}

deploy-receiver: require-protocol-rpc
    forge script scripts/DeployReceiver.s.sol:DeployReceiver --rpc-url {{ protocol_rpc }} {{ broadcast_flag }}

deploy-reactive-hub: require-reactive-rpc
    bash scripts/deployreactivehub.sh

activate-base-subscriptions: require-reactive-rpc
    bash scripts/activatebasesubscriptions.sh

deploy-hub:
    @just deploy-reactive-hub

# Full e2e: fresh deploy on protocol + reactive chains, then integration assertions.
e2e: require-reactive-rpc require-protocol-rpc
    bash test/e2e.sh

# Deploy MockLiquidityHub, BatchProcessSettlementReceiver, HubRSC; register recipients.

# Requires REACTIVE_RPC, PROTOCOL_RPC, PRIVATE_KEY (or REACTIVE_CI_PRIVATE_KEY), RECIPIENT_ONE, RECIPIENT_TWO.
e2e-deploy: require-reactive-rpc require-protocol-rpc
    bash test/e2e-deploy.sh

# Integration only against an existing deployment. Set at least:
#   REACTIVE_RPC, PROTOCOL_RPC, PRIVATE_KEY, LIQUIDITY_HUB, HUB_RSC, RECIPIENT_ONE, RECIPIENT_TWO
# Optional: LCC, SIBLING_LCC, UNDERLYING, SIBLING_UNDERLYING, MARKET_ID,
#           CHECK_AMOUNT_ONE, CHECK_AMOUNT_TWO, LIQUIDITY_AMOUNT,

# POLL_TIMEOUT_SECONDS, POLL_INTERVAL_SECONDS
e2e-integration: require-reactive-rpc require-protocol-rpc
    bash test/e2e-integration.sh

fund-contract contract_addr amount_wei:
    bash scripts/fundcontract.sh {{ contract_addr }} {{ amount_wei }}

contract-reserves contract_addr:
    cast call 0x0000000000000000000000000000000000fffFfF \
      "reserves(address)" \
      {{ contract_addr }} \
      --rpc-url https://mainnet-rpc.rnk.dev/ | cast to-dec

register-recipient recipient amount_wei: require-reactive-rpc
    bash scripts/registerrecipient.sh {{ recipient }} {{ amount_wei }}

fund-recipient recipient amount_wei: require-reactive-rpc
    bash scripts/fundrecipient.sh {{ recipient }} {{ amount_wei }}
