set dotenv-load
set export

rpc_url := env_var_or_default("ARB_MAINNET_RPC_URL", "")

[private]
default:
    @just help

help:
    @echo "7702 Emergency Unwrap"
    @echo "====================="
    @echo ""
    @echo "Recipes:"
    @echo "  just setup          - Build and deploy EOA 7702 implementation"
    @echo "  just preview-unwrap - Print unwrap tx calldata and suggested cast command"
    @echo "  just unwrap         - Execute single-tx EIP-7702 unwrap"
    @echo "  just preview-teardown - Print teardown command"
    @echo "  just teardown       - Re-delegate EOA away from emergency implementation"
    @echo "  just delegation-status - Inspect whether EOA currently has a 7702 delegation"
    @echo "  just fork-dry-run   - Dry-run unwrap call on local fork"
    @echo ""
    @echo "Required env vars:"
    @echo "  ARB_MAINNET_RPC_URL, LP_PRIVATE_KEY, EOA, POOL_MANAGER, LIQUIDITY_HUB, LCC_ADDRESS, IMPL"
    @echo "Optional:"
    @echo "  PRIVATE_KEY / DEPLOYER_PRIVATE_KEY for setup deploy"
    @echo "  AMOUNT (default 0 = unwrap full LCC balance)"
    @echo "  NEW_IMPL for teardown"
    @echo "  CLEAR_DELEGATION=1 to clear 7702 and restore plain EOA state"
    @echo "  TEARDOWN_GAS_LIMIT (default 100000)"

setup:
    mkdir -p deployments
    forge build && forge script script/Deploy7702Impl.s.sol:Deploy7702Impl \
        --rpc-url {{ rpc_url }} \
        --broadcast -vvv

preview-unwrap:
    forge script script/Run7702Unwrap.s.sol:Run7702Unwrap \
        --rpc-url {{ rpc_url }} -vvv

unwrap:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${EOA:?EOA is required}"
    : "${POOL_MANAGER:?POOL_MANAGER is required}"
    : "${LIQUIDITY_HUB:?LIQUIDITY_HUB is required}"
    : "${LCC_ADDRESS:?LCC_ADDRESS is required}"
    : "${IMPL:?IMPL is required}"
    : "${LP_PRIVATE_KEY:?LP_PRIVATE_KEY is required}"
    : "${ARB_MAINNET_RPC_URL:?ARB_MAINNET_RPC_URL is required}"

    SIGNER_EOA="$(cast wallet address --private-key "$LP_PRIVATE_KEY")"
    SIGNER_EOA_NORMALISED="$(printf '%s' "$SIGNER_EOA" | tr '[:upper:]' '[:lower:]')"
    EOA_NORMALISED="$(printf '%s' "$EOA" | tr '[:upper:]' '[:lower:]')"
    if [ "$SIGNER_EOA_NORMALISED" != "$EOA_NORMALISED" ]; then
      echo "LP_PRIVATE_KEY does not match EOA."
      echo "Derived signer: $SIGNER_EOA"
      echo "Expected EOA:  $EOA"
      exit 1
    fi

    AMOUNT_EFFECTIVE="${AMOUNT:-0}"
    if [ "$AMOUNT_EFFECTIVE" = "0" ]; then
      BAL_HEX="$(cast call "$LCC_ADDRESS" "balanceOf(address)(uint256)" "$EOA" --rpc-url "$ARB_MAINNET_RPC_URL")"
      BAL_HEX="$(printf '%s' "$BAL_HEX" | tr -d '[:space:]' | sed 's/\[[^][]*\]$//')"
      case "$BAL_HEX" in
        ""|"0x")
          echo "balanceOf(address) returned empty data for LCC_ADDRESS=$LCC_ADDRESS"
          echo "Check that LCC_ADDRESS is the correct ERC-20 LCC contract on this network."
          exit 1
          ;;
      esac
      AMOUNT_EFFECTIVE="$(python3 -c 'import sys; value = sys.argv[1].strip(); print(int(value, 0))' "$BAL_HEX" 2>/dev/null)" || {
        echo "Invalid balanceOf result: $BAL_HEX"
        exit 1
      }
    fi

    if [ "$AMOUNT_EFFECTIVE" = "0" ]; then
      echo "Amount to unwrap is zero."
      exit 1
    fi

    CHAIN_ID="$(cast chain-id --rpc-url "$ARB_MAINNET_RPC_URL")"
    CALLDATA="$(cast calldata "unlockAndUnwrap(address,address,address,uint256,uint256)" "$POOL_MANAGER" "$LIQUIDITY_HUB" "$LCC_ADDRESS" "$AMOUNT_EFFECTIVE" "$CHAIN_ID")"

    echo "EOA: $EOA"
    echo "Amount: $AMOUNT_EFFECTIVE"
    echo "Calldata: $CALLDATA"

    cast send "$EOA" \
      "unlockAndUnwrap(address,address,address,uint256,uint256)" \
      "$POOL_MANAGER" "$LIQUIDITY_HUB" "$LCC_ADDRESS" "$AMOUNT_EFFECTIVE" "$CHAIN_ID" \
      --auth "$IMPL" \
      --rpc-url "$ARB_MAINNET_RPC_URL" \
      --private-key "$LP_PRIVATE_KEY"

preview-teardown:
    forge script script/TeardownDelegation.s.sol:TeardownDelegation \
        --rpc-url {{ rpc_url }} -vvv

teardown:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${EOA:?EOA is required}"
    : "${LP_PRIVATE_KEY:?LP_PRIVATE_KEY is required}"
    : "${ARB_MAINNET_RPC_URL:?ARB_MAINNET_RPC_URL is required}"

    SIGNER_EOA="$(cast wallet address --private-key "$LP_PRIVATE_KEY")"
    SIGNER_EOA_NORMALISED="$(printf '%s' "$SIGNER_EOA" | tr '[:upper:]' '[:lower:]')"
    EOA_NORMALISED="$(printf '%s' "$EOA" | tr '[:upper:]' '[:lower:]')"
    if [ "$SIGNER_EOA_NORMALISED" != "$EOA_NORMALISED" ]; then
      echo "LP_PRIVATE_KEY does not match EOA."
      echo "Derived signer: $SIGNER_EOA"
      echo "Expected EOA:  $EOA"
      exit 1
    fi

    TARGET_IMPL="${NEW_IMPL:-0x0000000000000000000000000000000000000000}"
    GAS_LIMIT="${TEARDOWN_GAS_LIMIT:-100000}"
    if [ "${CLEAR_DELEGATION:-0}" = "1" ]; then
      TARGET_IMPL="0x0000000000000000000000000000000000000000"
      echo "Clearing 7702 delegation and restoring plain EOA state."
    fi

    if [ "${CLEAR_DELEGATION:-0}" != "1" ] && [ "$TARGET_IMPL" = "0x0000000000000000000000000000000000000000" ]; then
      echo "Set NEW_IMPL for teardown, or use CLEAR_DELEGATION=1 to clear 7702 entirely."
      exit 1
    fi

    cast send "$EOA" \
      --auth "$TARGET_IMPL" \
      --gas-limit "$GAS_LIMIT" \
      --rpc-url "$ARB_MAINNET_RPC_URL" \
      --private-key "$LP_PRIVATE_KEY"

delegation-status:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${EOA:?EOA is required}"
    : "${ARB_MAINNET_RPC_URL:?ARB_MAINNET_RPC_URL is required}"

    ACCOUNT_CODE="$(cast code "$EOA" --rpc-url "$ARB_MAINNET_RPC_URL")"
    ACCOUNT_CODE="$(printf '%s' "$ACCOUNT_CODE" | tr -d '[:space:]')"

    if [ -z "$ACCOUNT_CODE" ] || [ "$ACCOUNT_CODE" = "0x" ]; then
      echo "EOA: $EOA"
      echo "Status: plain EOA"
      echo "Delegation: none"
      exit 0
    fi

    if python3 -c 'import re, sys; sys.exit(0 if re.fullmatch(r"0xef0100[0-9a-fA-F]{40}", sys.argv[1].strip()) else 1)' "$ACCOUNT_CODE"; then
      IMPL_ADDRESS="0x$(printf '%s' "$ACCOUNT_CODE" | cut -c9-48)"
      echo "EOA: $EOA"
      echo "Status: EIP-7702 delegation active"
      echo "Delegation implementation: $IMPL_ADDRESS"
      exit 0
    fi

    echo "EOA: $EOA"
    echo "Status: non-empty code, but not a recognised EIP-7702 delegation indicator"
    echo "Account code: $ACCOUNT_CODE"
    exit 1

fork-dry-run:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${ANVIL_FORK_URL:?ANVIL_FORK_URL is required, e.g. http://localhost:8545}"
    : "${EOA:?EOA is required}"
    : "${POOL_MANAGER:?POOL_MANAGER is required}"
    : "${LIQUIDITY_HUB:?LIQUIDITY_HUB is required}"
    : "${LCC_ADDRESS:?LCC_ADDRESS is required}"
    : "${IMPL:?IMPL is required}"
    : "${LP_PRIVATE_KEY:?LP_PRIVATE_KEY is required}"

    SIGNER_EOA="$(cast wallet address --private-key "$LP_PRIVATE_KEY")"
    SIGNER_EOA_NORMALISED="$(printf '%s' "$SIGNER_EOA" | tr '[:upper:]' '[:lower:]')"
    EOA_NORMALISED="$(printf '%s' "$EOA" | tr '[:upper:]' '[:lower:]')"
    if [ "$SIGNER_EOA_NORMALISED" != "$EOA_NORMALISED" ]; then
      echo "LP_PRIVATE_KEY does not match EOA."
      echo "Derived signer: $SIGNER_EOA"
      echo "Expected EOA:  $EOA"
      exit 1
    fi

    AMOUNT_EFFECTIVE="${AMOUNT:-0}"
    if [ "$AMOUNT_EFFECTIVE" = "0" ]; then
      BAL_HEX="$(cast call "$LCC_ADDRESS" "balanceOf(address)(uint256)" "$EOA" --rpc-url "$ANVIL_FORK_URL")"
      BAL_HEX="$(printf '%s' "$BAL_HEX" | tr -d '[:space:]' | sed 's/\[[^][]*\]$//')"
      case "$BAL_HEX" in
        ""|"0x")
          echo "balanceOf(address) returned empty data for LCC_ADDRESS=$LCC_ADDRESS"
          echo "Check that LCC_ADDRESS is the correct ERC-20 LCC contract on this fork."
          exit 1
          ;;
      esac
      AMOUNT_EFFECTIVE="$(python3 -c 'import sys; value = sys.argv[1].strip(); print(int(value, 0))' "$BAL_HEX" 2>/dev/null)" || {
        echo "Invalid balanceOf result: $BAL_HEX"
        exit 1
      }
    fi

    if [ "$AMOUNT_EFFECTIVE" = "0" ]; then
      echo "Amount to unwrap is zero."
      exit 1
    fi

    CHAIN_ID="$(cast chain-id --rpc-url "$ANVIL_FORK_URL")"
    CALLDATA="$(cast calldata "unlockAndUnwrap(address,address,address,uint256,uint256)" "$POOL_MANAGER" "$LIQUIDITY_HUB" "$LCC_ADDRESS" "$AMOUNT_EFFECTIVE" "$CHAIN_ID")"
    PRE_LCC_BALANCE="$(cast call "$LCC_ADDRESS" "balanceOf(address)(uint256)" "$EOA" --rpc-url "$ANVIL_FORK_URL")"
    PRE_LCC_BALANCE="$(printf '%s' "$PRE_LCC_BALANCE" | tr -d '[:space:]' | sed 's/\[[^][]*\]$//')"

    echo "Executing fork dry-run against: $ANVIL_FORK_URL"
    echo "EOA: $EOA"
    echo "Amount: $AMOUNT_EFFECTIVE"
    echo "Pre LCC balance: $(python3 -c 'import sys; print(int(sys.argv[1].strip(), 0))' "$PRE_LCC_BALANCE")"
    echo "Calldata: $CALLDATA"

    cast send "$EOA" \
      "unlockAndUnwrap(address,address,address,uint256,uint256)" \
      "$POOL_MANAGER" "$LIQUIDITY_HUB" "$LCC_ADDRESS" "$AMOUNT_EFFECTIVE" "$CHAIN_ID" \
      --auth "$IMPL" \
      --rpc-url "$ANVIL_FORK_URL" \
      --private-key "$LP_PRIVATE_KEY"

    POST_LCC_BALANCE="$(cast call "$LCC_ADDRESS" "balanceOf(address)(uint256)" "$EOA" --rpc-url "$ANVIL_FORK_URL")"
    POST_LCC_BALANCE="$(printf '%s' "$POST_LCC_BALANCE" | tr -d '[:space:]' | sed 's/\[[^][]*\]$//')"
    PRE_DEC="$(python3 -c 'import sys; print(int(sys.argv[1].strip(), 0))' "$PRE_LCC_BALANCE")"
    POST_DEC="$(python3 -c 'import sys; print(int(sys.argv[1].strip(), 0))' "$POST_LCC_BALANCE")"

    echo "Post LCC balance: $POST_DEC"
    if [ "$POST_DEC" -ge "$PRE_DEC" ]; then
      echo "Fork dry-run did not reduce the LCC balance."
      exit 1
    fi
